# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(git gpg-agent keychain)

source $ZSH/oh-my-zsh.sh

# Editor
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nano'
fi

# Starship prompt
eval "$(starship init zsh)"

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# pnpm
export PNPM_HOME="{{ .chezmoi.homeDir }}/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# GPG
export GPG_TTY=$(tty)

# Local bin (cursor, etc.)
export PATH="$HOME/.local/bin:$PATH"

# Java (Android SDK)
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home

# RVM
export PATH="$PATH:$HOME/.rvm/bin"
[[ -s "$HOME/.rvm/scripts/rvm" ]] && source "$HOME/.rvm/scripts/rvm"

# Aliases
alias cc="claude --worktree"
alias brew-sync="brew bundle dump --file=~/dev/dotfiles/Brewfile --force --no-vscode --no-uv && echo 'Brewfile updated. Run chezmoi apply or commit to sync.'"

# Try.rb
eval "$(~/.local/try.rb init ~/dev/tries)"

# Notion API key for Claude Code MCP integration
export NOTION_API_KEY="{{ onepasswordRead "op://Qraft/chezmoi_notion/api_key" "my.1password.eu" }}"

# Slack MCP tokens
export SLACK_QRAFT_USER_TOKEN="{{ onepasswordRead "op://Qraft/chezmoi_slack-qraft/user_token" "my.1password.eu" }}"
export SLACK_EPISTO_USER_TOKEN="{{ onepasswordRead "op://Qraft/chezmoi_slack-episto/user_token" "my.1password.eu" }}"
