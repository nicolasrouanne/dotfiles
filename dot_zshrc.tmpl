# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(git gpg-agent keychain)

source $ZSH/oh-my-zsh.sh

# Editor
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nano'
fi

# Starship prompt
eval "$(starship init zsh)"

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# pnpm
export PNPM_HOME="{{ .chezmoi.homeDir }}/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# GPG
export GPG_TTY=$(tty)

# Local bin (cursor, etc.)
export PATH="$HOME/.local/bin:$PATH"

# Java (Android SDK)
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home

# RVM
export PATH="$PATH:$HOME/.rvm/bin"
[[ -s "$HOME/.rvm/scripts/rvm" ]] && source "$HOME/.rvm/scripts/rvm"

# Aliases
alias cc="claude --worktree"
alias brew-sync="brew bundle dump --file=~/dev/dotfiles/Brewfile --force --no-vscode --no-uv && echo 'Brewfile updated. Run chezmoi apply or commit to sync.'"

# Try.rb
eval "$(~/.local/try.rb init ~/dev/tries)"

# 1Password Service Account token (from macOS Keychain)
export OP_SERVICE_ACCOUNT_TOKEN=$(security find-generic-password -a "sa-claude-code" -s "1password-service-account" -w)

# Notion API keys for Claude Code MCP integration
export NOTION_TOKEN_PERSONAL="{{ onepasswordRead "op://AI Agents/chezmoi_notion_personal/api_key" }}"
export NOTION_TOKEN_WORK="{{ onepasswordRead "op://AI Agents/chezmoi_notion_work/api_key" }}"

# Notion CLI (ntn) — workspace switching via NOTION_API_TOKEN env override
# (ntn login is blocked on Plus plan: requests Workers capability bundle)
ntn-pro()   { NOTION_API_TOKEN="$NOTION_TOKEN_WORK"     ntn "$@"; }
ntn-perso() { NOTION_API_TOKEN="$NOTION_TOKEN_PERSONAL" ntn "$@"; }

# Slack MCP tokens
export SLACK_QRAFT_USER_TOKEN="{{ onepasswordRead "op://AI Agents/chezmoi_slack-qraft/user_token" }}"
export SLACK_EPISTO_USER_TOKEN="{{ onepasswordRead "op://AI Agents/chezmoi_slack-episto/user_token" }}"

# Toggl
export TOGGL_API_TOKEN="{{ onepasswordRead "op://AI Agents/chezmoi_toggl/api_token" }}"

# Langfuse API keys
export LANGFUSE_PUBLIC_KEY="{{ onepasswordRead "op://AI Agents/chezmoi_langfuse/public_key" }}"
export LANGFUSE_SECRET_KEY="{{ onepasswordRead "op://AI Agents/chezmoi_langfuse/secret_key" }}"

# Qonto MCP credentials
export QONTO_API_KEY="{{ onepasswordRead "op://AI Agents/chezmoi_qonto/api_key" }}"
export QONTO_ORGANIZATION_ID="{{ onepasswordRead "op://AI Agents/chezmoi_qonto/organization_id" }}"
